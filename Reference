void toLowerCase(string &s)  {
   
    for (int i = 0; i < s.length(); i++) {
       
        s[i]=tolower(s[i]);

    }

}

//pt 2
void doubleValue(int &x) {

    x *= 2;

}

// pt 3
int addRandom(int x) {

    return x + (rand() % 10 + 1);

}


